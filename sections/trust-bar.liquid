<div class="trust-bar">
  <div class="trust-container">
    {% for block in section.blocks %}
      <div class="trust-item" {{ block.shopify_attributes }}>
        <div class="icon-wrap">{{ block.settings.icon }}</div>
        <h4>{{ block.settings.title }}</h4>
        <p>{{ block.settings.subtitle }}</p>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji/Icon",
          "default": "🚚"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free UK Delivery"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "On orders over £50"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "🚚", "title": "Free UK Delivery", "subtitle": "On orders over £50" } },
        { "type": "trust_item", "settings": { "icon": "🛡️", "title": "30-Day Guarantee", "subtitle": "Money-back promise" } },
        { "type": "trust_item", "settings": { "icon": "🌿", "title": "100% Natural", "subtitle": "No harsh chemicals" } },
        { "type": "trust_item", "settings": { "icon": "🔒", "title": "Secure Checkout", "subtitle": "SSL encrypted" } }
      ]
    }
  ]
}
{% endschema %}
