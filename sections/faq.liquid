<section class="section" id="faq">
  <div class="section-container">
    <div class="section-header">
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>

    <div class="faq-list">
      {% for block in section.blocks %}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <div class="faq-question">
            <span>{{ block.settings.question }}</span>
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Frequently Asked" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Got Questions? We've Got Answers." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long until I see results?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Most customers see noticeable changes within 4-6 weeks." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "How long until I see results?", "answer": "Most customers see noticeable changes within 4-6 weeks. Full results typically appear after 60-90 days of consistent daily use." } },
        { "type": "faq", "settings": { "question": "Is it safe for daily use?", "answer": "Absolutely. Forget White is made from 100% natural ingredients with no ammonia, peroxide, or harsh chemicals." } },
        { "type": "faq", "settings": { "question": "Do you deliver across the UK?", "answer": "Yes. We deliver to all UK addresses. Orders over £50 ship free, taking 2-4 working days." } },
        { "type": "faq", "settings": { "question": "What if it doesn't work for me?", "answer": "We offer a 30-day money-back guarantee. Return the product within 30 days for a full refund." } }
      ]
    }
  ]
}
{% endschema %}
